rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(data) {
      return request.auth.uid == data.userId;
    }

    function isPublic(data) {
      return data.privacy == 'public';
    }

    function isSharedWithMe(data) {
      // privacy == 'shared' and the caller's verified email is in sharedEmails
      return data.privacy == 'shared' &&
             request.auth.token.email != null &&
             request.auth.token.email in data.sharedEmails;
    }

    function hasPendingTransferForCaller(transferId) {
      return transferId is string &&
             exists(/databases/$(database)/documents/compositionOwnershipTransfers/$(transferId)) &&
             get(/databases/$(database)/documents/compositionOwnershipTransfers/$(transferId)).data.status == 'pending' &&
             request.auth.token.email != null &&
             get(/databases/$(database)/documents/compositionOwnershipTransfers/$(transferId)).data.toEmail == request.auth.token.email;
    }

    function isOwnershipTransferAcceptance(dataBefore, dataAfter) {
      return dataBefore.pendingOwnershipTransferId is string &&
             hasPendingTransferForCaller(dataBefore.pendingOwnershipTransferId) &&
             dataAfter.userId == request.auth.uid &&
             dataAfter.pendingOwnershipTransferId == null;
    }

    match /compositions/{compositionId} {

      // Read: owner, or public, or explicitly shared with the caller's email
      allow read: if isAuthenticated() &&
                     (isOwner(resource.data) ||
                      isPublic(resource.data) ||
                      isSharedWithMe(resource.data));

      // Create: authenticated user, must set their own userId; title must be a string.
      allow create: if isAuthenticated() &&
                       request.resource.data.userId == request.auth.uid &&
                       request.resource.data.title is string;

      // Update: immutable fields (userId, createdAt) must not change, PLUS the caller
      // must be one of:
      //   1. The owner of the composition.
      //   2. A user explicitly shared (privacy='shared') with 'edit' permission.
      //   3. Any authenticated user when the composition is public with 'edit' permission.
      allow update: if isAuthenticated() &&
                       request.resource.data.createdAt == resource.data.createdAt &&
                       (
                         (
                           request.resource.data.userId == resource.data.userId &&
                           (isOwner(resource.data) ||
                            (isSharedWithMe(resource.data) &&
                             resource.data.sharePermission == 'edit') ||
                            (isPublic(resource.data) &&
                             resource.data.sharePermission == 'edit'))
                         ) ||
                         isOwnershipTransferAcceptance(resource.data, request.resource.data)
                       );

      // Delete: owner only
      allow delete: if isAuthenticated() && isOwner(resource.data);
    }

    function compositionDoc(compositionId) {
      return get(/databases/$(database)/documents/compositions/$(compositionId));
    }

    function compositionExists(compositionId) {
      return exists(/databases/$(database)/documents/compositions/$(compositionId));
    }

    function canReadComposition(compositionId) {
      return compositionExists(compositionId) &&
             (isOwner(compositionDoc(compositionId).data) ||
              isPublic(compositionDoc(compositionId).data) ||
              isSharedWithMe(compositionDoc(compositionId).data));
    }

    function canEditComposition(compositionId) {
      return compositionExists(compositionId) &&
             (isOwner(compositionDoc(compositionId).data) ||
              (isSharedWithMe(compositionDoc(compositionId).data) &&
               compositionDoc(compositionId).data.sharePermission == 'edit') ||
              (isPublic(compositionDoc(compositionId).data) &&
               compositionDoc(compositionId).data.sharePermission == 'edit'));
    }

    function threadDoc(threadId) {
      return get(/databases/$(database)/documents/compositionCommentThreads/$(threadId));
    }

    function threadExists(threadId) {
      return exists(/databases/$(database)/documents/compositionCommentThreads/$(threadId));
    }

    function canReadThread(threadId) {
      return threadExists(threadId) &&
             threadDoc(threadId).data.compositionId is string &&
             canReadComposition(threadDoc(threadId).data.compositionId);
    }

    function transferDoc(transferId) {
      return get(/databases/$(database)/documents/compositionOwnershipTransfers/$(transferId));
    }

    function transferExists(transferId) {
      return exists(/databases/$(database)/documents/compositionOwnershipTransfers/$(transferId));
    }

    // Version history snapshots stored separately for retention control.
    match /compositionRevisions/{revisionId} {
      // Viewers can read timeline for compositions they can access.
      allow read: if isAuthenticated() &&
                    resource.data.compositionId is string &&
                    canReadComposition(resource.data.compositionId);

      // Only editors can add revisions tied to an editable composition.
      allow create: if isAuthenticated() &&
                      request.resource.data.compositionId is string &&
                      canEditComposition(request.resource.data.compositionId);

      // Revisions are immutable; no client updates.
      allow update: if false;

      // Pruning old revisions is done by editors.
      allow delete: if isAuthenticated() &&
                      resource.data.compositionId is string &&
                      canEditComposition(resource.data.compositionId);
    }

    // Live editor presence (who is in a score + cursor/selection metadata).
    match /compositionPresence/{presenceId} {
      allow read: if isAuthenticated() &&
                    resource.data.compositionId is string &&
                    canReadComposition(resource.data.compositionId);

      allow create: if isAuthenticated() &&
                      request.resource.data.compositionId is string &&
                      request.resource.data.uid == request.auth.uid &&
                      canReadComposition(request.resource.data.compositionId);

      allow update: if isAuthenticated() &&
                      resource.data.uid == request.auth.uid &&
                      request.resource.data.uid == resource.data.uid &&
                      request.resource.data.compositionId == resource.data.compositionId &&
                      canReadComposition(resource.data.compositionId);

      allow delete: if isAuthenticated() &&
                      (
                        resource.data.uid == request.auth.uid ||
                        (
                          resource.data.compositionId is string &&
                          canEditComposition(resource.data.compositionId)
                        )
                      );
    }

    // Per-measure real-time co-edit patches.
    match /compositionMeasurePatches/{patchId} {
      allow read: if isAuthenticated() &&
                    resource.data.compositionId is string &&
                    canReadComposition(resource.data.compositionId);

      allow create: if isAuthenticated() &&
                      request.resource.data.compositionId is string &&
                      request.resource.data.actorUid == request.auth.uid &&
                      request.resource.data.staffIndex is number &&
                      request.resource.data.measureIndex is number &&
                      canEditComposition(request.resource.data.compositionId);

      allow update: if false;

      allow delete: if isAuthenticated() &&
                      resource.data.compositionId is string &&
                      canEditComposition(resource.data.compositionId);
    }

    // Asynchronous review threads tied to a specific staff + measure.
    match /compositionCommentThreads/{threadId} {
      allow read: if isAuthenticated() &&
                    resource.data.compositionId is string &&
                    canReadComposition(resource.data.compositionId);

      allow create: if isAuthenticated() &&
                      request.resource.data.compositionId is string &&
                      request.resource.data.staffIndex is number &&
                      request.resource.data.measureIndex is number &&
                      request.resource.data.status == 'open' &&
                      canReadComposition(request.resource.data.compositionId);

      // Allow status transitions (open <-> resolved) and last-comment metadata updates.
      // Immutable: composition/target location/creator identity.
      allow update: if isAuthenticated() &&
                      resource.data.compositionId is string &&
                      canReadComposition(resource.data.compositionId) &&
                      request.resource.data.compositionId == resource.data.compositionId &&
                      request.resource.data.staffIndex == resource.data.staffIndex &&
                      request.resource.data.measureIndex == resource.data.measureIndex &&
                      request.resource.data.createdBy == resource.data.createdBy;

      // Owner can delete by compositionId (new docs) OR by thread ownership fallback
      // for legacy comments that may not store compositionId.
      allow delete: if isAuthenticated() &&
                      (
                        (
                          resource.data.compositionId is string &&
                          compositionExists(resource.data.compositionId) &&
                          isOwner(compositionDoc(resource.data.compositionId).data)
                        ) ||
                        (
                          resource.data.threadId is string &&
                          threadExists(resource.data.threadId) &&
                          threadDoc(resource.data.threadId).data.compositionId is string &&
                          compositionExists(threadDoc(resource.data.threadId).data.compositionId) &&
                          isOwner(compositionDoc(threadDoc(resource.data.threadId).data.compositionId).data)
                        )
                      );
    }

    // Individual comments belonging to a thread.
    match /compositionThreadComments/{commentId} {
      allow read: if isAuthenticated() &&
                    resource.data.threadId is string &&
                    canReadThread(resource.data.threadId);

      allow create: if isAuthenticated() &&
                      request.resource.data.threadId is string &&
                      request.resource.data.compositionId is string &&
                      request.resource.data.content is string &&
                      request.resource.data.staffIndex is number &&
                      request.resource.data.measureIndex is number &&
                      threadExists(request.resource.data.threadId) &&
                      threadDoc(request.resource.data.threadId).data.compositionId == request.resource.data.compositionId &&
                      canReadComposition(request.resource.data.compositionId);

      allow update: if false;

      allow delete: if isAuthenticated() &&
                      resource.data.compositionId is string &&
                      compositionExists(resource.data.compositionId) &&
                      isOwner(compositionDoc(resource.data.compositionId).data);
    }

    // Ownership transfer requests for handing off composition ownership.
    match /compositionOwnershipTransfers/{transferId} {
      allow read: if isAuthenticated() &&
                    (
                      resource.data.fromUid == request.auth.uid ||
                      (request.auth.token.email != null &&
                       resource.data.toEmail == request.auth.token.email)
                    );

      allow create: if isAuthenticated() &&
                      request.resource.data.compositionId is string &&
                      request.resource.data.fromUid == request.auth.uid &&
                      request.resource.data.toEmail is string &&
                      request.resource.data.status == 'pending' &&
                      compositionExists(request.resource.data.compositionId) &&
                      isOwner(compositionDoc(request.resource.data.compositionId).data);

      // Sender can cancel. Recipient can accept/decline.
      allow update: if isAuthenticated() &&
                      resource.data.status == 'pending' &&
                      (
                        (
                          resource.data.fromUid == request.auth.uid &&
                          request.resource.data.status == 'cancelled'
                        ) ||
                        (
                          request.auth.token.email != null &&
                          resource.data.toEmail == request.auth.token.email &&
                          (request.resource.data.status == 'accepted' ||
                           request.resource.data.status == 'declined' ||
                           request.resource.data.status == 'expired')
                        )
                      ) &&
                      request.resource.data.compositionId == resource.data.compositionId &&
                      request.resource.data.fromUid == resource.data.fromUid &&
                      request.resource.data.toEmail == resource.data.toEmail;

      allow delete: if isAuthenticated() &&
                      resource.data.compositionId is string &&
                      compositionExists(resource.data.compositionId) &&
                      isOwner(compositionDoc(resource.data.compositionId).data);
    }

    // Scanned / OCR import jobs — owner only
    match /scanned/{jobId} {
      // Read: owner only (backend sets owner = request.auth.uid)
      allow read: if isAuthenticated() && request.auth.uid == resource.data.owner;

      // Delete: owner only
      allow delete: if isAuthenticated() && request.auth.uid == resource.data.owner;

      // No create/update from the client — the backend writes these docs
      allow create, update: if false;
    }

    // Per-account onboarding/preferences for editor guidance.
    match /userOnboarding/{uid} {
      allow read, create, update: if isAuthenticated() && request.auth.uid == uid;
      allow delete: if false;
    }

    // Deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
