rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(data) {
      return request.auth.uid == data.userId;
    }

    function isPublic(data) {
      return data.privacy == 'public';
    }

    function isSharedWithMe(data) {
      // privacy == 'shared' and the caller's verified email is in sharedEmails
      return data.privacy == 'shared' &&
             request.auth.token.email != null &&
             request.auth.token.email in data.sharedEmails;
    }

    match /compositions/{compositionId} {

      // Read: owner, or public, or explicitly shared with the caller's email
      allow read: if isAuthenticated() &&
                     (isOwner(resource.data) ||
                      isPublic(resource.data) ||
                      isSharedWithMe(resource.data));

      // Create: authenticated user, must set their own userId; title must be a string.
      allow create: if isAuthenticated() &&
                       request.resource.data.userId == request.auth.uid &&
                       request.resource.data.title is string;

      // Update: immutable fields (userId, createdAt) must not change, PLUS the caller
      // must be one of:
      //   1. The owner of the composition.
      //   2. A user explicitly shared (privacy='shared') with 'edit' permission.
      //   3. Any authenticated user when the composition is public with 'edit' permission.
      allow update: if isAuthenticated() &&
                       request.resource.data.userId == resource.data.userId &&
                       request.resource.data.createdAt == resource.data.createdAt &&
                       (isOwner(resource.data) ||
                        (isSharedWithMe(resource.data) &&
                         resource.data.sharePermission == 'edit') ||
                        (isPublic(resource.data) &&
                         resource.data.sharePermission == 'edit'));

      // Delete: owner only
      allow delete: if isAuthenticated() && isOwner(resource.data);
    }

    function compositionDoc(compositionId) {
      return get(/databases/$(database)/documents/compositions/$(compositionId));
    }

    function compositionExists(compositionId) {
      return exists(/databases/$(database)/documents/compositions/$(compositionId));
    }

    function canReadComposition(compositionId) {
      return compositionExists(compositionId) &&
             (isOwner(compositionDoc(compositionId).data) ||
              isPublic(compositionDoc(compositionId).data) ||
              isSharedWithMe(compositionDoc(compositionId).data));
    }

    function canEditComposition(compositionId) {
      return compositionExists(compositionId) &&
             (isOwner(compositionDoc(compositionId).data) ||
              (isSharedWithMe(compositionDoc(compositionId).data) &&
               compositionDoc(compositionId).data.sharePermission == 'edit') ||
              (isPublic(compositionDoc(compositionId).data) &&
               compositionDoc(compositionId).data.sharePermission == 'edit'));
    }

    // Version history snapshots stored separately for retention control.
    match /compositionRevisions/{revisionId} {
      // Viewers can read timeline for compositions they can access.
      allow read: if isAuthenticated() &&
                    resource.data.compositionId is string &&
                    canReadComposition(resource.data.compositionId);

      // Only editors can add revisions tied to an editable composition.
      allow create: if isAuthenticated() &&
                      request.resource.data.compositionId is string &&
                      canEditComposition(request.resource.data.compositionId);

      // Revisions are immutable; no client updates.
      allow update: if false;

      // Pruning old revisions is done by editors.
      allow delete: if isAuthenticated() &&
                      resource.data.compositionId is string &&
                      canEditComposition(resource.data.compositionId);
    }

    // Scanned / OCR import jobs — owner only
    match /scanned/{jobId} {
      // Read: owner only (backend sets owner = request.auth.uid)
      allow read: if isAuthenticated() && request.auth.uid == resource.data.owner;

      // Delete: owner only
      allow delete: if isAuthenticated() && request.auth.uid == resource.data.owner;

      // No create/update from the client — the backend writes these docs
      allow create, update: if false;
    }

    // Deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
