# Firebase Configuration
# Copy this file to .env and fill in your Firebase project credentials
# Get these values from: Firebase Console > Project Settings > General > Your apps > Web app

# API Key (public, safe to expose in client-side code)
VITE_FIREBASE_API_KEY=your-api-key-here

# Auth Domain (your project's Firebase domain)
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com

# Project ID (your Firebase project identifier)
VITE_FIREBASE_PROJECT_ID=your-project-id

# Storage Bucket (for file storage, if needed)
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com

# Messaging Sender ID (for push notifications, if needed)
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789012

# App ID (your Firebase app identifier)
VITE_FIREBASE_APP_ID=1:123456789012:web:abcdef1234567890

# OMR API Configuration
# Base URL for the OMR Backend API
# Development: http://localhost:8000
# Production: https://your-backend-domain.com
VITE_OMR_API_BASE_URL=http://localhost:8000

# AI Assistant (Help page chat)
# Get a free API key from https://aistudio.google.com/apikey
# Optional: Leave unset to disable AI chat; documentation and FAQ still work
VITE_GEMINI_API_KEY=your-gemini-api-key

# ============================================
# How to get these values:
# ============================================
# 
# QUICK START:
# 1. Go to https://console.firebase.google.com/
# 2. Create a new project (or select existing)
# 3. Click the web icon (</>) to "Add app"
# 4. Register your app with any nickname
# 5. Copy the firebaseConfig values shown
# 6. Paste them below (replace the placeholder values)
#
# DETAILED GUIDE: See FIREBASE_SETUP.md for step-by-step instructions
#
# Alternative method (if app already exists):
# - Click gear icon (⚙️) > Project Settings
# - Scroll to "Your apps" section
# - Click on your web app to see the config
#
# Example firebaseConfig from Firebase Console:
# const firebaseConfig = {
#   apiKey: "AIzaSy...",
#   authDomain: "myproject.firebaseapp.com",
#   projectId: "myproject",
#   storageBucket: "myproject.appspot.com",
#   messagingSenderId: "123456789",
#   appId: "1:123456789:web:abc123"
# };
#
# Map to .env:
# apiKey -> VITE_FIREBASE_API_KEY
# authDomain -> VITE_FIREBASE_AUTH_DOMAIN
# projectId -> VITE_FIREBASE_PROJECT_ID
# storageBucket -> VITE_FIREBASE_STORAGE_BUCKET
# messagingSenderId -> VITE_FIREBASE_MESSAGING_SENDER_ID
# appId -> VITE_FIREBASE_APP_ID
